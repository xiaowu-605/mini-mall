{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash(npm*)",
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npm install *)",
      "Bash(timeout 5 pnpm dev:server)",
      "Bash(npx prisma *)",
      "Bash(npx tsx *)",
      "Bash(curl -s http://localhost:3000/api/categories)",
      "Bash(curl -s \"http://localhost:3000/api/products?pageSize=2\")",
      "Bash(curl -s \"http://localhost:3000/api/products?search=键盘\")",
      "Bash(curl -s \"http://localhost:3000/api/products/1\")",
      "Bash(curl -s \"http://localhost:3000/api/products?search=%E9%94%AE%E7%9B%98\")",
      "WebFetch(domain:github.com)",
      "Bash(pnpm remove *)",
      "Bash(pnpm add *)",
      "Bash(pnpm format *)",
      "Bash(timeout 10 pnpm dev:frontend)",
      "Bash(pnpm format:check)",
      "Bash(timeout 8 pnpm dev:frontend)",
      "Bash(curl -s -X POST http://localhost:3000/api/auth/register -H 'Content-Type: application/json' -d '{\"email\":\"test@test.com\",\"password\":\"123456\",\"name\":\"测试用户\"}' -c /tmp/cookies.txt)",
      "Bash(curl -s http://localhost:3000/api/auth/me -b /tmp/cookies.txt)",
      "Bash(curl -s -X POST http://localhost:3000/api/auth/register -H 'Content-Type: application/json' -d '{\"email\":\"test@test.com\",\"password\":\"123456\",\"name\":\"重复\"}')",
      "Bash(curl -s -X POST http://localhost:3000/api/auth/login -H 'Content-Type: application/json' -d '{\"email\":\"test@test.com\",\"password\":\"123456\"}' -c /tmp/cookies2.txt)",
      "Bash(pkill -f \"tsx.*server\")",
      "Bash(netstat -ano)",
      "Bash(taskkill //PID 16476 //F)",
      "Bash(curl -s -X POST http://localhost:3000/api/auth/login -H 'Content-Type: application/json' -d '{\"email\":\"test@test.com\",\"password\":\"123456\"}')",
      "Bash(mkdir -p home login register product-detail)",
      "Bash(mv HomePage.vue home/)",
      "Bash(mv LoginPage.vue login/)",
      "Bash(mv RegisterPage.vue register/)",
      "Bash(mv ProductDetailPage.vue product-detail/)",
      "Bash(gh pr *)",
      "Bash(winget install *)",
      "Bash(gh auth *)",
      "Bash(npx vue-tsc *)",
      "Bash(npx prettier *)",
      "Bash(taskkill //PID 4908 //F)",
      "Bash(curl -s -X POST http://localhost:3000/api/orders -H \"Content-Type: application/json\" -d '{}')",
      "Bash(taskkill //PID 25316 //F)",
      "Bash(npx tsc *)",
      "Bash(npx vite *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "autoCompactWindow": 800000
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"文件已修改，建议检查一下改了什么\""
          }
        ]
      }
    ]
  }
}
