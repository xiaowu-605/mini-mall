{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash(npm*)",
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npm install *)",
      "Bash(timeout 5 pnpm dev:server)",
      "Bash(npx prisma *)",
      "Bash(npx tsx *)",
      "Bash(curl -s http://localhost:3000/api/categories)",
      "Bash(curl -s \"http://localhost:3000/api/products?pageSize=2\")",
      "Bash(curl -s \"http://localhost:3000/api/products?search=键盘\")",
      "Bash(curl -s \"http://localhost:3000/api/products/1\")",
      "Bash(curl -s \"http://localhost:3000/api/products?search=%E9%94%AE%E7%9B%98\")",
      "WebFetch(domain:github.com)",
      "Bash(pnpm remove *)",
      "Bash(pnpm add *)",
      "Bash(pnpm format *)",
      "Bash(timeout 10 pnpm dev:frontend)",
      "Bash(pnpm format:check)",
      "Bash(timeout 8 pnpm dev:frontend)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "autoCompactWindow": 800000
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"文件已修改，建议检查一下改了什么\""
          }
        ]
      }
    ]
  }
}
