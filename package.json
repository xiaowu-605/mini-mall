{
  "name": "mini-mall",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx server/index.ts\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "format": "prettier --write \"src/**/*.{vue,ts,css,less}\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,css,less}\" \"server/**/*.ts\"",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "element-plus": "^2.14.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "prettier": "^3.9.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.4.10",
    "vue-tsc": "^2.1.10"
  }
}
